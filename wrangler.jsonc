// Configuração do Cloudflare Workers (com Static Assets).
// Serve o site estático da AGA Móveis a partir da pasta dist/.
// Documentação: https://developers.cloudflare.com/workers/static-assets/
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aga-moveis-site",
  "compatibility_date": "2026-05-27",
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
